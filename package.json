{
	"name": "@idleberg/configs",
	"version": "0.4.6",
	"description": "A collection of configuration files for my own projects",
	"license": "MIT",
	"author": "Jan T. Sott",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/idleberg/configs.git"
	},
	"type": "module",
	"exports": {
		"./biome": "./biome.jsonc",
		"./tsc": "./tsconfig.json",
		"./tsconfig": "./tsconfig.json"
	},
	"files": [
		"biome.jsonc",
		"tsconfig.json"
	],
	"scripts": {
		"lint": "concurrently --prefix-colors blue,green,magenta npm:lint:*",
		"lint:biome": "biome check",
		"lint:e18e": "e18e-cli analyze --log-level error",
		"publish:npm": "np --no-release-draft",
		"test": "exit 0"
	},
	"dependencies": {
		"@biomejs/biome": "^2.5.0",
		"@e18e/cli": "^0.7.0",
		"@total-typescript/tsconfig": "^1.0.4",
		"lefthook": "^2.1.9"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"concurrently": "^10.0.3",
		"np": "^11.2.1"
	},
	"packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
